    minRsi,
    maxRsi,
    minAdx,
    volumeMultiplier,
    breakoutLookback,
    minAtr,
    sampleTrades
)
SELECT t.ticker,
       CASE
           WHEN t.ticker IN ('HDFCBANK.NS','ICICIBANK.NS','AXISBANK.NS','SBIN.NS',
                             'KOTAKBANK.NS','BANKBARODA.NS','PNB.NS','CANBK.NS')
               THEN '^NSEBANK'

           WHEN t.ticker IN ('INFY.NS','TCS.NS','WIPRO.NS','TECHM.NS','HCLTECH.NS')
               THEN '^CNXIT'

           WHEN t.ticker IN ('TATASTEEL.NS','JSWSTEEL.NS','SAIL.NS','NMDC.NS','GPIL.NS')
               THEN '^CNXMETAL'

           WHEN t.ticker IN ('SUNPHARMA.NS','DIVISLAB.NS','ALKEM.NS')
               THEN '^CNXPHARMA'

           WHEN t.ticker IN ('RELIANCE.NS','ONGC.NS','IOC.NS','BPCL.NS',
                             'NTPC.NS','POWERGRID.NS','COALINDIA.NS')
               THEN '^CNXENERGY'

           WHEN t.ticker IN ('MARUTI.NS')
               THEN '^CNXAUTO'

           WHEN t.ticker IN ('HINDUNILVR.NS','ITC.NS','ASIANPAINT.NS','TITAN.NS')
               THEN '^CNXFMCG'

           WHEN t.ticker IN ('LT.NS','NBCC.NS','SIEMENS.NS','CGPOWER.NS','IRFC.NS')
               THEN '^CNXINFRA'

           WHEN t.ticker IN ('BAJFINANCE.NS','IIFL.NS','ABSLAMC.NS')
               THEN '^NSEBANK'

           WHEN t.ticker IN ('IDEA.NS')
